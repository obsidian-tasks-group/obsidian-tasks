{
	"name": "obsidian-tasks",
	"version": "7.23.2",
	"description": "Task management for the Obsidian knowledge base",
	"main": "main.js",
	"engines": {
		"node": ">=18.0.0"
	},
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "node esbuild.config.mjs production",
		"build:dev": "node esbuild.config.mjs development",
		"lint": "eslint ./src --fix && eslint ./tests --fix && tsc --noEmit --pretty && svelte-check",
		"lint:markdown": "markdownlint-cli2 --fix \"**/*.md\" ",
		"test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --ci",
		"test:dev": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch",
		"test:integration": "jest --config jest.integration.config.js",
		"deploy:local": "pwsh -ExecutionPolicy Unrestricted -NoProfile -File ./scripts/Test-TasksInLocalObsidian.ps1",
		"extract-i18n": "npx i18next-parser",
		"circular-deps-text": "madge --circular --extensions ts ./src > circular-deps.txt",
		"circular-deps-image": "madge --circular --extensions ts ./src --image circular-deps.png",
		"code-docs": "typedoc \"src/**/*\""
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"obsidian-tasks",
		"task-manager",
		"task-management"
	],
	"author": "Clare Macrae and Ilyas Landikov (created by Martin Schenck)",
	"license": "MIT",
	"devDependencies": {
		"@codemirror/view": "^6.39.0",
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^9.39.0",
		"@evilmartians/lefthook": "^1.11.0",
		"@swc/core": "^1.15.21",
		"@swc/jest": "^0.2.39",
		"@testing-library/jest-dom": "^6.6.0",
		"@testing-library/svelte": "^5.0.0",
		"@tsconfig/svelte": "^5.0.8",
		"@types/jest": "^29.5.8",
		"@types/mustache": "^4.2.5",
		"@typescript-eslint/eslint-plugin": "^8.0.0",
		"@typescript-eslint/parser": "^8.0.0",
		"approvals": "^6.2.4",
		"async-mutex": "^0.5.0",
		"builtin-modules": "^5.0.0",
		"esbuild": "0.28.0",
		"esbuild-sass-plugin": "^3.2.0",
		"esbuild-svelte": "^0.9.0",
		"eslint": "^9.39.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-import": "^2.31.0",
		"eslint-plugin-prettier": "^5",
		"eslint-plugin-svelte": "^2.46.0",
		"i18next-parser": "^9.1.0",
		"jest": "^29.7.0",
		"jest-environment-jsdom": "^29.7.0",
		"madge": "^8.0.0",
		"markdownlint-cli2": "^0.22.0",
		"moment": "^2.30.0",
		"obsidian": "^1.12.3",
		"obsidian-typings": "^2.11.1",
		"prettier": "^3",
		"prettier-plugin-svelte": "^3",
		"svelte": "^5.50.0",
		"svelte-check": "^4.3.0",
		"svelte-eslint-parser": "^0.43.0",
		"svelte-jester": "^5.0.0",
		"svelte-preprocess": "^6.0.0",
		"ts-jest": "^29.4.0",
		"tslib": "^2.8.1",
		"typedoc": "^0.27.3",
		"typedoc-plugin-mdn-links": "^5.1.1",
		"typedoc-umlclass": "^0.10.1",
		"typescript": "^5.8.0"
	},
	"dependencies": {
		"@floating-ui/dom": "^1.7.5",
		"boon-js": "^2.0.5",
		"chrono-node": "2.7.9",
		"eventemitter2": "^6.4.9",
		"flatpickr": "^4.6.13",
		"i18next": "^24.2.1",
		"mustache": "^4.2.0",
		"mustache-validator": "^0.2.0",
		"rrule": "^2.8.1"
	}
}
